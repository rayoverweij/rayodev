						</svg>
					</A>

					<A title="GitHub" href="https://github.com/rayoverweij"
						class="group absolute bottom-0 left-42 md:top-2.25 md:left-29 lg:top-3.5 w-10 h-10 border border-black dark:border-violet-700 dark:hover:border-violet-800 rounded-full overflow-hidden flex items-center justify-center"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="w-10 h-10 fill-black dark:fill-violet-700 dark:hover:fill-violet-800 scale-105 group-hover:scale-115 transition-transform">
