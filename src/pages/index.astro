						</svg>
					</A>

					<A title="Orcid" href="https://orcid.org/0009-0007-8996-0233"
						class="group block absolute bottom-0 left-28 md:top-2.5 md:left-17.5 lg:top-2 w-10 h-10 px-1 py-1.25 rounded-full bg-[#A6CE39] hover:bg-[#7D9B2C] transition"
					>
