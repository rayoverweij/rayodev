---
import { Picture } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import A from "@components/A.astro";
import TimelineSegment from "@components/TimelineSegment.astro";
import banner from "@assets/banner.png";
import profilepic from "@assets/rayo.jpg";
import infint from "@assets/infint.png";
import iep from "@assets/iep.webp";
import sibb from "@assets/sibb.jpg";
import voxsio_clinicians from "@assets/voxsio_clinicians.jpg";

const highlights = [
	{
		src: infint,
		alt: "An AI-generated image in the style of vintage adventure book covers of two children being sucked into a black box by what looks like a neural net",
		title: `“INFERENCE INTERFERENCE"`,
		href: "/inference-interference",
		external: false,
		style: "font-della tracking-wider text-lg bg-red-200 -rotate-[0.5deg]",
		rotate: ""
	},
	{
		src: iep,
		alt: "Three children sitting around a table, one drawing a translation app on a tablet, another drawing it on paper, and the third is filling out a worksheet",
		title: "How Children Design the Future of AI in Primary Schools",
		href: "/designing-future-ai-schools",
		external: false,
		style: "bg-yellow-200 -rotate-1"
	},
	{
		src: sibb,
		alt: "A few people standing around or in a large black box on stilts that has a few coloured post-its on its side",
		title: "Stepping Into the Black Box of AI",
		href: "https://designinformatics.org/portfolio-item/stepping-into-the-black-box-of-ai/",
		external: true,
		style: "bottom-10 bg-green-200 rotate-1 md:rotate-2"
	},
	{
		src: voxsio_clinicians,
		alt: "A drawing of a humanoid sunflower, Ubee, standing between three clinicians in lab coats",
		title: "Voxsio: building ethical digital health apps with NHS Grampian",
		href: "https://voxsio.com",
		external: true,
		style: "bg-sky-200 -rotate-[0.5deg]"
	}
];

const interests = [
	{
		emoji: "🔗",
		title: "AI literacy",
		style: "left-6 bg-pink-300/50 -rotate-6",
		lines: 1
	},
	{
		emoji: "🤝",
		title: "Co-creation",
		style: "left-42 bg-sky-300/50",
		lines: 1
	},
	{
		emoji: "🤯",
		title: "Theory of mind\n& AI",
		style: "top-28 -left-3 bg-lime-300/50 rotate-2",
		lines: 2
	},
	{
		emoji: "🏗️",
		title: "Construct-ionism",
		style: "top-24 left-26 bg-yellow-300/50 -rotate-2",
		lines: 2
	},
	{
		emoji: "🔮",
		title: "Speculative design",
		style: "top-26 left-54 bg-purple-300/50 rotate-3",
		lines: 2
	},
	{
		emoji: "🖱️",
		title: "Child-computer interaction",
		style: "top-51 left-10 bg-teal-300/50 rotate-1",
		lines: 2
	},
	{
		emoji: "🎒",
		title: "Responsible EdTech",
		style: "top-53 left-39 bg-red-300/50 -rotate-4",
		lines: 2
	},
];
---

<BaseLayout
	title="Home"
	desc="Rayo is a PhD researcher at the Centre for Doctoral Training in Designing Responsible Natural Language Processing at the University of Edinburgh."
	ogImageData={banner}
	ogImageAlt="Rayo Verweij: researcher, designer, developer. Working on young people's critical understanding of new technologies like AI through designing and building their own tools."
>
	<main class="max-w-7xl 2xl:max-w-368 mx-auto">
		<div class="md:max-w-198 lg:max-w-216 xl:max-w-236 mt-4 md:mt-[12.5vh] md:mx-auto px-4 md:px-8 lg:px-0 flex flex-col md:flex-row">
			<div class="relative mb-8 md:mb-0 pb-12 md:pb-0 flex flex-col-reverse md:flex-col items-center md:items-start">
				<div>
					<h1>Rayo Verwe&IJlig;</h1>
					<div class="max-w-54 lg:max-w-full mb-2 px-px flex justify-between text-black/70 dark:text-rock-100/70">
						<span>he/they</span>
						<span>&middot;</span>
						<span>/rah-yo ver-wai/</span>
					</div>
				</div>

				<Picture
					src={profilepic}
					formats={["avif"]}
					alt="A headshot of Rayo smiling at the camera"
					priority
					width={256}
					height={306}
					pictureAttributes={{ class: "relative w-54 lg:w-64 h-64 lg:h-76 mb-4 md:mb-0 border border-black rounded-t-[200px] rounded-b-3xl md:rounded-t-3xl md:rounded-b-[200px] shadow-light overflow-hidden"}}
				/>

				<div class="absolute left-[calc(50%-6.5rem)] bottom-0 md:relative md:left-0">
					<A title="Bluesky" href="https://bsky.app/profile/rayo.dev"
						class="group block absolute bottom-0 left-0 md:-top-8 md:-left-2 lg:-top-9 w-10 h-10 p-2 rounded-full bg-[#1B73FA] hover:bg-[#2066D0] transition"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="w-6 h-6 pt-px fill-white group-hover:scale-110 transition">
							<path d="M3.468 1.948C5.303 3.325 7.276 6.118 8 7.616c.725-1.498 2.698-4.29 4.532-5.668C13.855.955 16 .186 16 2.632c0 .489-.28 4.105-.444 4.692-.572 2.04-2.653 2.561-4.504 2.246 3.236.551 4.06 2.375 2.281 4.2-3.376 3.464-4.852-.87-5.23-1.98-.07-.204-.103-.3-.103-.218 0-.081-.033.014-.102.218-.379 1.11-1.855 5.444-5.231 1.98-1.778-1.825-.955-3.65 2.28-4.2-1.85.315-3.932-.205-4.503-2.246C.28 6.737 0 3.12 0 2.632 0 .186 2.145.955 3.468 1.948"/>
						</svg>
					</A>

					<A title="LinkedIn" href="https://linkedin.com/in/rayo-verweij"
						class="group block absolute bottom-0 left-14 md:-top-1 md:left-7 lg:-top-2 w-10 h-10 p-1.5 rounded-full bg-[#1866BE] hover:bg-[#124B8D] transition"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 72 72" class="w-7 h-7 fill-white group-hover:scale-110 transition">
